---
import type { Prank } from "../lib/pranks";

interface Props {
  prank: Prank;
}

const { prank } = Astro.props;
---

<a
  href={`/${prank.id}`}
  class="prank-row group flex items-start gap-4 px-4 py-4 sm:py-3.5 border-b border-[var(--color-border)] hover:bg-[var(--color-border-light)] transition-colors duration-100"
  data-tags={prank.tags.join(",")}
  data-chaos={prank.chaos}
  data-subtlety={prank.subtlety}
  data-detection={prank.detection}
  data-name={prank.name.toLowerCase()}
>
  {/* Left: name, tagline, tags */}
  <div class="flex-1 min-w-0">
    <h3 class="text-sm font-semibold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
      {prank.name}
    </h3>
    <p class="text-xs text-[var(--color-text-muted)] italic font-mono truncate mt-0.5">
      {prank.tagline}
    </p>
    <div class="flex flex-wrap gap-1.5 mt-1.5">
      {prank.tags.map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>

  {/* Right: stats */}
  <div class="flex items-center gap-3 shrink-0 pt-0.5">
    <div class="stat-group">
      <span class="stat-label">S</span>
      <span class="stat-value" style={`color: var(--color-subtlety)`}>{prank.subtlety}</span>
    </div>
    <div class="stat-group">
      <span class="stat-label">C</span>
      <span class="stat-value" style={`color: var(--color-chaos)`}>{prank.chaos}</span>
    </div>
    <div class="stat-group">
      <span class="stat-label">D</span>
      <span class="stat-value" style={`color: var(--color-stealth)`}>{prank.detection}</span>
    </div>
  </div>
</a>

<style>
  .stat-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 1.75rem;
  }
  .stat-label {
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    line-height: 1;
  }
  .stat-value {
    font-size: 1.125rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    line-height: 1.3;
  }
</style>
