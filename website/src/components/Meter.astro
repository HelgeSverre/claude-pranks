---
interface Props {
  value: number;
  max?: number;
  color: string;
  label: string;
}

const { value, max = 10, color, label } = Astro.props;
const pct = (value / max) * 100;
---

<div class="flex items-center gap-3 text-xs">
  <span class="w-14 text-[var(--color-text-secondary)] shrink-0 font-medium">{label}</span>
  <div class="flex-1 h-1.5 rounded-full bg-[var(--color-border-light)] overflow-hidden">
    <div class="meter-fill h-full rounded-full" style={`width: ${pct}%; background: ${color};`}></div>
  </div>
  <span class="text-[var(--color-text-muted)] w-4 text-right tabular-nums">{value}</span>
</div>
