---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<button
  class="copy-btn text-xs px-3 py-1.5 rounded border border-[var(--color-border)] text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-text-secondary)] transition-colors cursor-pointer"
  data-copy={text}
>
  Copy to clipboard
</button>

<script>
  document.querySelectorAll(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = (btn as HTMLElement).dataset.copy || "";
      await navigator.clipboard.writeText(text);
      const original = btn.textContent;
      btn.textContent = "Copied!";
      setTimeout(() => {
        btn.textContent = original;
      }, 2000);
    });
  });
</script>
